{
  "name": "iobroker.alarmmanager",
  "version": "0.0.3",
  "description": "Pager alarm system via e*Message API with escalation, acknowledgements and state-based triggers",
  "author": {
    "name": "TobiasP",
    "email": "app@gmail.com"
  },
  "contributors": [],
  "homepage": "https://github.com/t0Puk/ioBroker.alarmmanager",
  "license": "MIT",
  "keywords": [
    "alarm",
    "pager",
    "emessage",
    "alert",
    "notification",
    "escalation",
    "iobroker",
    "ecityruf",
    "2ways",
    "ebos"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/t0Puk/ioBroker.alarmmanager.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/adapter-react": "^2.0.22",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@material-ui/core": "^4.12.4",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "@types/node": "^20.19.37",
    "@types/react": "^17.0.91",
    "@types/react-dom": "^17.0.26",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/build/",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build admin/build",
    "build": "build-adapter all",
    "watch": "build-adapter all --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "prebuild:react": "rimraf admin/build",
    "build:react": "build-adapter react",
    "watch:react": "build-adapter react --watch",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit && tsc --noEmit -p admin/tsconfig.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server"
  },
  "bugs": {
    "url": "https://github.com/t0Puk/ioBroker.alarmmanager/issues"
  },
  "readmeFilename": "README.md"
}
